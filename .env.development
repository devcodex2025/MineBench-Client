# Development Environment Variables
# Використовується для локальної розробки

# Wallet Authorization
VITE_WALLET_AUTH_URL=http://localhost:3000/auth

# API Endpoints
VITE_API_BASE_URL=http://localhost:3000/api

# Backend Services
VITE_BACKEND_URL=http://localhost:3000

# Wallet Service
VITE_WALLET_SERVICE_URL=http://localhost:3000/wallet

# Multi-device Sync
VITE_SYNC_SERVICE_URL=ws://localhost:3000/sync

# Solana RPC (Devnet for development)
VITE_SOLANA_RPC_URL=https://api.devnet.solana.com

# Pool API
VITE_POOL_API_URL=http://localhost:8080/api
