# Production Environment Variables
# Використовується для production збірки

# Wallet Authorization
VITE_WALLET_AUTH_URL=https://minebench.cloud/auth

# API Endpoints
VITE_API_BASE_URL=https://minebench.cloud/api

# Backend Services
VITE_BACKEND_URL=https://minebench.cloud

# Wallet Service
VITE_WALLET_SERVICE_URL=https://minebench.cloud/wallet

# Multi-device Sync
VITE_SYNC_SERVICE_URL=wss://minebench.cloud/sync

# Solana RPC (Mainnet for production)
VITE_SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# Pool API
VITE_POOL_API_URL=https://minebench.cloud/api/pool
