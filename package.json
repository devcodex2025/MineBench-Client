{
  "name": "MineBench-Client",
  "private": true,
  "version": "0.3.0",
  "productName": "MineBench Client",
  "description": "Mining benchmark desktop client with native Wayland support.",
  "author": "MineBench Team",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "clean": "rimraf dist",
    "build": "vite build",
    "dist": "npm run clean && vite build && electron-builder",
    "dist:win": "npm run clean && vite build && electron-builder --win --publish=never",
    "dist:mac": "npm run clean && vite build && electron-builder --mac --publish=never",
    "dist:linux": "npm run clean && vite build && electron-builder --linux --publish=never",
    "dist:all": "npm run clean && vite build && electron-builder -mwl --publish=never",
    "build:icon": "node ./scripts/make-icon.cjs",
    "electron": "electron electron/main.cjs",
    "dev:all": "concurrently \"npm run dev\" \"wait-on http://localhost:5173 && npm run electron\"",
    "release:patch": "npm version patch && git push && git push --tags",
    "release:minor": "npm version minor && git push && git push --tags",
    "release:major": "npm version major && git push && git push --tags"
  },
  "dependencies": {
    "@react-three/drei": "^9.114.3",
    "@react-three/fiber": "^8.17.10",
    "@supabase/supabase-js": "^2.76.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.562.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-is": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "recharts": "^3.2.1",
    "systeminformation": "^5.27.11",
    "tailwind-merge": "^3.4.0",
    "three": "^0.161.0",
    "zustand": "^5.0.10"
  },
  "main": "electron/main.cjs",
  "devDependencies": {
    "@eslint/js": "^9.36.0",
    "@tailwindcss/postcss": "^4.1.18",
    "@types/node": "^24.6.1",
    "@types/react": "^19.1.16",
    "@types/react-dom": "^19.1.9",
    "@types/three": "^0.165.0",
    "@vitejs/plugin-react": "^5.0.3",
    "autoprefixer": "^10.4.23",
    "concurrently": "^9.2.1",
    "electron": "^31.6.1",
    "electron-builder": "^26.0.12",
    "eslint": "^9.36.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.4.0",
    "png-to-ico": "^2.0.0",
    "postcss": "^8.5.6",
    "rimraf": "^6.0.1",
    "tailwindcss": "^4.1.18",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.44.0",
    "vite": "^7.1.7",
    "wait-on": "^9.0.1"
  },
  "build": {
    "appId": "com.minebench.client",
    "productName": "MineBench Client",
    "files": [
      "web-dist/**/*",
      "electron/**/*",
      "Miner/**/*",
      "build/icon.ico",
      "build/icon.png",
      "build/icon.icns",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "build/icon.ico",
      "artifactName": "${productName}-${version}-Windows-${arch}-setup.${ext}"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "build/icon.icns",
      "category": "public.app-category.utilities",
      "artifactName": "${productName}-${version}-macOS-${arch}.${ext}"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.png",
      "category": "Utility",
      "executableName": "minebench-client"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "MineBench Client",
      "deleteAppDataOnUninstall": false,
      "runAfterFinish": true,
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "license": null,
      "warningsAsErrors": false
    },
    "extraFiles": [
      {
        "from": "Miner",
        "to": "Miner",
        "filter": [
          "**/*"
        ]
      }
    ],
    "directories": {
      "output": "dist"
    },
    "publish": {
      "provider": "github",
      "owner": "devcodex2025",
      "repo": "MineBench-Client"
    }
  }
}
